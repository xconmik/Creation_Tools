# Optional path to JSON config (defaults to ./config/config.json)
CONFIG_JSON_PATH=./config/config.json

# Required target website URL
TARGET_URL=https://example.com/register

# Project name used for logs and output naming
PROJECT_NAME=default-project

# Comma-separated list of domains for random email generation
EMAIL_DOMAINS=example.com,testmail.com

# Optional comma-separated list of proxies (http:// or socks5://)
PROXIES=http://127.0.0.1:8080,socks5://127.0.0.1:9050

# Optional comma-separated list of header IPs to rotate per run (sets X-Forwarded-For and X-Real-IP)
HEADER_IPS=49.181.220.228,81.2.69.160

# Number of test submissions to run
TEST_SUBMISSIONS=5

# true/false
HEADLESS=true

# Optional: absolute path to Chromium executable (useful for packaged .exe deployments)
BROWSER_EXECUTABLE_PATH=
